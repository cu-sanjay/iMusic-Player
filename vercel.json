{
  "version": 2,
  "builds": [
    {
      "src": "src/pages/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "src/pages/api/convert.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/convert",
      "dest": "/api/convert"
    },
    {
      "src": "/(.*)",
      "dest": "/index"
    }
  ]
}