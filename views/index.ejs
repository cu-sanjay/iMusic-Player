<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>utubemusic - YouTube to MP3</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="icon" href="/images/utubemusic-icon.png" type="image/png" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
</head>
<body>
  <div class="container">
    <div class="branding">
      <img src="/images/UTUBELogo.png" alt="utubemusic logo" />
    </div>
    <form action="/convert-mp3" method="POST" id="form">
      <h1>utubemusic</h1>
      <p>Convert YouTube videos to high-quality MP3</p>
      <input type="text" name="url" placeholder="Enter YouTube URL..." required />
      <button type="submit"><i class="fas fa-download"></i> Convert</button>
    </form>
    <p class="footer">Built by <a href="https://github.com/cu-sanjay" target="_blank">cu-sanjay</a> • Hosted on <a href="https://vercel.com" target="_blank">Vercel</a></p>
  </div>
</body>
</html>
